# Copia questo file in ".env" e inserisci la tua chiave.
# Le variabili SENZA prefisso EXPO_PUBLIC_ restano solo lato server (API route)
# e non finiscono nel bundle dell'app.

# Chiave API Anthropic (obbligatoria) — usata dalla route /api/analyze.
ANTHROPIC_API_KEY=sk-ant-...

# Modello di visione per la descrizione frame-by-frame.
# Default: claude-haiku-4-5 — il più veloce ed economico, minore latenza, ideale
# per la cattura continua. Alternativa più accurata (ma più lenta e costosa):
#   claude-opus-4-8
ANTHROPIC_MODEL=claude-haiku-4-5

# (Facoltativo) URL assoluto dell'API.
# In sviluppo NON serve: l'app rileva da sola l'host del dev server Metro.
# Serve solo per build standalone / produzione, es:
# EXPO_PUBLIC_API_URL=https://tuo-server.example.com
