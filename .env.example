# Copia questo file in ".env" e inserisci la tua chiave.
# Le variabili SENZA prefisso EXPO_PUBLIC_ restano solo lato server (API route)
# e non finiscono nel bundle dell'app.

# Chiave API Anthropic (obbligatoria) — usata dalla route /api/analyze.
ANTHROPIC_API_KEY=sk-ant-...

# Modello di visione per la descrizione frame-by-frame.
# Default: claude-haiku-4-5 — il più veloce ed economico, minore latenza, ideale
# per la cattura continua. Alternativa più accurata (ma più lenta e costosa):
#   claude-opus-4-8
ANTHROPIC_MODEL=claude-haiku-4-5

# (Facoltativo) URL assoluto dell'API.
# In sviluppo NON serve: l'app rileva da sola l'host del dev server Metro.
# Serve solo per build standalone / produzione, es:
# EXPO_PUBLIC_API_URL=https://tuo-server.example.com


# --- Supabase (autenticazione) ---------------------------------------------
# Dashboard → Project Settings → API.

# URL del progetto — client (prefisso EXPO_PUBLIC_ => entra nel bundle app).
EXPO_PUBLIC_SUPABASE_URL=https://tuo-progetto.supabase.co

# Publishable key (sb_publishable_...) — sicura lato client, va nel bundle.
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Secret key (sb_secret_...) — SOLO lato server (route /api), MAI nel client.
# Serve a verificare i token degli utenti in /api/analyze.
SUPABASE_SECRET_KEY=sb_secret_...

# Protezione dell'endpoint a pagamento /api/analyze.
# "true"  => richiede un token Supabase valido (abilita prima gli accessi
#            anonimi sul dashboard, altrimenti l'app nativa non avrà un token).
# Non impostata / "false" => il token viene verificato se presente ma non è
#            obbligatorio (default, non rompe l'app).
# ANALYZE_REQUIRE_AUTH=true
